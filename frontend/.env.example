# ════════════════════════════════════════════════════════════════════════════════
# Frontend Environment Variables (.env.example)
# Copy this file to .env.local and fill in with your actual values
# For production on Render, set these in the Dashboard instead of in .env files
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────────────────────────────────────
# For development: http://localhost:5000
# For production: https://airo-backend-xxx.onrender.com
# This variable is PUBLIC (visible in browser) so prefix with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────────────────────────
# Node Environment
# ──────────────────────────────────────────────────────────────────────────────
# Values: development, production
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# Node.js Optimization
# ──────────────────────────────────────────────────────────────────────────────
# Increase memory for builds (especially on limited systems)
# For development: --max-old-space-size=512
# For production: --max-old-space-size=1024
NODE_OPTIONS=--max-old-space-size=1024
